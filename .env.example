# Copy this file to .env and set real values.
# Do not commit secrets.

# Database target
DATABASE_ACCESS=local
# local, staging, production

# Database - Local
DB_HOST=localhost
DB_PORT=3306
DB_USER=health_agent_user
DB_PASSWORD=replace_with_secure_password
PUBLISH_DB_NAME=your_database_name
AGENT_DB_NAME=health_ai_agent

# Optional staging target
# STAGING_DB_HOST=staging-db-host
# STAGING_DB_PORT=25060
# STAGING_DB_USER=staging_user
# STAGING_DB_PASSWORD=replace_with_staging_password
# STAGING_PUBLISH_DB_NAME=mydrscripts_staging
# STAGING_AGENT_DB_NAME=health_ai_agent_staging

# Optional production target
# PRODUCTION_DB_HOST=production-db-host
# PRODUCTION_DB_PORT=3306
# PRODUCTION_DB_USER=production_user
# PRODUCTION_DB_PASSWORD=replace_with_production_password
# PRODUCTION_PUBLISH_DB_NAME=your_database_name
# PRODUCTION_AGENT_DB_NAME=health_ai_agent

# Run behavior
RUN_MODE=production
# Optional: set externally to override generated ID per run
# RUN_ID=run-20260306T120000Z-1234

# Optional: Spaces file upload for blog_master.file backfill/publication
# SPACES_ENDPOINT=nyc3.digitaloceanspaces.com
# SPACES_BUCKET=mydrscripts-public
# SPACES_REGION=nyc3
# SPACES_KEY=your_spaces_access_key
# SPACES_SECRET=your_spaces_secret_key
# SPACES_PREFIX=blog-master

# Optional: app-backed blog image upload flow
# API_URL=https://app.example.com/api/
# BLOG_IMAGE_API_BASE_URL=https://app.example.com
# BLOG_IMAGE_UPLOAD_PATH=doctor/upload-temp-file
# BLOG_IMAGE_MOVE_PATH=doctor/move-temp-file
# BLOG_IMAGE_DESTINATION_FOLDER=blog-master
# BLOG_IMAGE_MOVE_PUBLIC=1
# BLOG_IMAGE_API_HEADERS_JSON={"Authorization":"Bearer replace_me"}

# Optional: continuous wrapper cooldown in seconds (default: 120)
# COOLDOWN_SECONDS=120

# Optional: launcher overrides for start-agent, scripts/start_agent.py, or scripts/start_agent.ps1
# AGENT_PYTHON_COMMAND=python
# AGENT_START_RECENCY_HOURS=24
# AGENT_START_COMMAND=python scripts/run_workflow.py --recency-hours 24

# Optional: dashboard login gate for `python3 scripts/agent_dashboard.py --serve`
# 0 = disabled, 1 = enabled
# DASHBOARD_LOGIN_ENABLED=0
# DASHBOARD_LOGIN_USERNAME=admin
# DASHBOARD_LOGIN_PASSWORD=change_me
# DASHBOARD_LOGIN_SECRET=change_me_too

# Optional: operational storage backend and dashboard source
AGENT_STORAGE_BACKEND=json
# database = existing MySQL-backed operational tables
# json = current-directory JSON files only
# both = write to MySQL and JSON files
DASHBOARD_DATA_SOURCE=json
# database = read dashboard data from health_ai_agent tables
# json = read dashboard data from agent_run_logs.json + agent_memory.json
AGENT_JSON_STORAGE_DIR=.
# Optional: explicit blog JSON file or directory overrides for frontend blog APIs
# AGENT_BLOGS_JSON_PATH=.
# BLOG_JSON_PATH=logs

# Optional: browser-based verification/search runtime
# GOOGLE_CHROME_MCP_ENABLED=1
# GOOGLE_CHROME_MCP_SERVER=google-chrome-mcp
